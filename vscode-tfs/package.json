{
    "name": "tfs-for-vscode-chinese",
    "version": "3.0.10",
    "description": "TFS Visual Studio Code 集成扩展。",
    "license": "SEE LICENSE IN LICENSE",
    "main": "./out/extension",
    "scripts": {
        "vscode:prepublish": "yarn run compile",
        "precompile": "yarn run rimraf out",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "yarn run compile && yarn run lint",
        "test": "mocha -r ts-node/register \"src/**/*.spec.ts\"",
        "lint": "eslint src --ext ts",
        "fix": "prettier --write \"src/**/*.ts\"",
        "start": "node src/extension.js --loadGenerated"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "devDependencies": {
        "@types/jsonfile": "^6.1.4",
        "@types/mocha": "^7.0.2",
        "@types/node": "^13.11.0",
        "@types/vscode": "^1.86.0",
        "@types/xml2js": "^0.4.14",
        "@typescript-eslint/eslint-plugin": "^3.1.0",
        "@typescript-eslint/parser": "^3.1.0",
        "eslint": "7.2.0",
        "eslint-config-prettier": "^6.11.0",
        "eslint-plugin-mocha": "7.0.1",
        "eslint-plugin-prettier": "^3.1.3",
        "mocha": "^7.2.0",
        "prettier": "^2.0.5",
        "rimraf": "^3.0.2",
        "ts-node": "^8.10.2",
        "typescript": "4.5.5"
    },
    "engines": {
        "vscode": "^1.86.0"
    },
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "pending-changes",
                    "title": "TFServer (TFS) 版本控制",
                    "icon": "res/image.png"
                }
            ]
        },
        "views": {
            "pending-changes": [
                {
                    "id": "pendingChanges",
                    "contents": "",
                    "name": "已暂存的更改",
                    "icon": "res/image.png",
                    "contextualTitle": "挂起的更改",
                    "type": "tree"
                },
                {
                    "id": "currentFileHistory",
                    "contents": "",
                    "name": "当前文件更改记录",
                    "icon": "res/image.png",
                    "contextualTitle": "历史记录",
                    "type": "tree"
                }
            ]
        },
        "commands": [
            {
                "command": "pendingChanges.openFile",
                "title": "打开文件",
                "enablement": "true"
            },
            {
                "command": "tfs.statusbar.workspace",
                "title": "工作区",
                "icon": "res/workspace.png",
                "enablement": "true"
            },
            {
                "command": "pendingChanges.compareFiles",
                "title": "与最新版本比较",
                "enablement": "true"
            },
            {
                "command": "pendingChanges.undo",
                "title": "撤销更改",
                "enablement": "true"
            },
            {
                "command": "fileHistory.comapreWithAnother",
                "title": "比较",
                "enablement": "true"
            },
            {
                "command": "vscode-tfs.get",
                "title": "获取最新版本",
                "detail": "获取文件的最新版本。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.checkout",
                "title": "签出编辑",
                "detail": "签出文件并将其挂起更改状态设置为编辑。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.checkin",
                "detail": "将挂起的更改签入到 TFS。",
                "title": "签入",
                "category": "TFS"
            },
            {
                "command": "pendingChanges.checkin",
                "title": "签入所选文件",
                "detail": "签入选中的文件到 TFS。",
                "category": "TFS"
            },
            {
                "command": "pendingChanges.checkinAll",
                "title": "签入所有更改",
                "detail": "签入所有挂起的更改到 TFS。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.add",
                "title": "添加",
                "detail": "将文件和文件夹添加到版本控制。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.delete",
                "title": "删除",
                "detail": "从 TFS 中移除文件和文件夹并从磁盘删除。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.undo",
                "title": "撤销挂起的更改",
                "detail": "放弃一个或多个文件或文件夹的挂起更改。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.openInBrowser",
                "title": "在浏览器中打开",
                "detail": "在浏览器中打开文件和文件夹。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.list",
                "title": "Team Foundation Server...",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.testAnnotate",
                "title": "测试标注命令",
                "detail": "测试标注命令输出解析。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.testBlameIntegration",
                "title": "测试 Blame 集成",
                "detail": "测试 Blame 功能集成。",
                "category": "TFS"
            },
            {
                "command": "vscode-tfs.showBlame",
                "title": "TFS: 标注",
                "detail": "TFS: 标注",
                "category": "TFS"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "pendingChanges.checkinAll",
                    "when": "view == pendingChanges",
                    "group": "navigation@1"
                }
            ],
            "view/item/context": [
                {
                    "command": "pendingChanges.compareFiles",
                    "when": "view == pendingChanges",
                    "group": "1_compare@1"
                },
                {
                    "command": "pendingChanges.checkin",
                    "when": "view == pendingChanges",
                    "group": "2_checkin@2"
                },
                {
                    "command": "pendingChanges.undo",
                    "when": "view == pendingChanges",
                    "group": "3_undo@3"
                },
                {
                    "command": "fileHistory.comapreWithAnother",
                    "when": "view == currentFileHistory",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "vscode-tfs.list",
                    "when": "false"
                }
            ],
            "explorer/context": [
                {
                    "command": "vscode-tfs.list"
                }
            ],
            "editor/title/context": [
                {
                    "command": "vscode-tfs.list"
                }
            ],
            "editor/context": [
                {
                    "command": "vscode-tfs.showBlame",
                    "when": "editorTextFocus",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "TFS 配置",
            "properties": {
                "tfs.location": {
                    "type": "string",
                    "description": "TFS 命令行客户端 (tf.exe) 的路径。"
                },
                "tfs.promptToCheckOut": {
                    "type": "boolean",
                    "description": "True -> 在 Team Foundation Server 中弹出签出提示\n False -> 自动签出文件。"
                },
                "tfs.tfptLocation": {
                    "type": "string",
                    "description": "TFS Power Tools 命令行客户端 (tfpt.exe) 的路径。"
                },
                "tfs.blame.enabled": {
                    "type": "boolean",
                    "description": "启用/禁用标注功能。",
                    "default": true
                },
                "tfs.blame.cacheSize": {
                    "type": "number",
                    "description": "标注信息缓存的最大文件数。",
                    "default": 50
                }
            }
        },
        "keybindings": [
            {
                "command": "vscode-tfs.list",
                "key": "Alt+T"
            }
        ]
    },
    "homepage": "https://github.com/Keysqiu",
    "author": {
        "name": "Keysqiu",
        "email": "2586597832@qq.com",
        "url": "https://github.com/Keysqiu"
    },
    "publisher": "keysqiu",
    "repository": {
        "type": "git",
        "url": "https://github.com/Keysqiu/svetlyotfs.git"
    },
    "bugs": {
        "url": "https://github.com/Keysqiu/svetlyotfs/issues"
    },
    "readmeFilename": "README.md",
    "displayName": "TFS TFVC Chinese",
    "icon": "res/image.png",
    "galleryBanner": {
        "color": "#912a2a",
        "theme": "dark"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "tfs",
        "team",
        "foundation",
        "server",
        "microsoft"
    ],
    "dependencies": {
        "fs-extra": "^11.2.0",
        "iconv-lite": "^0.4.24",
        "json-file": "^0.1.0",
        "jsonfile": "^6.1.0",
        "xml2js": "^0.6.2"
    }
}
